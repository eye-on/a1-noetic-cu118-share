{
  "name": "a1-noetic-cu118",
  "dockerComposeFile": [
    "../docker-compose.yml"
  ],
  "service": "a1-dev",
  "workspaceFolder": "/ws",
  "shutdownAction": "stopCompose",
  "overrideCommand": false,
  "remoteUser": "root",
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      },
      "extensions": [
        "ms-iot.vscode-ros",
        "ms-python.python",
        "ms-vscode.cpptools",
        "ms-vscode.cmake-tools"
      ]
    }
  }
}
